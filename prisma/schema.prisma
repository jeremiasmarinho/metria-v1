generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  connections AgencyConnection[]
  clients     Client[]
  users       User[]

  @@map("agencies")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  password          String
  role              UserRole           @default(ANALYST)
  agencyId          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  agencyConnections AgencyConnection[]
  agency            Agency             @relation(fields: [agencyId], references: [id])

  @@map("users")
}

model AgencyConnection {
  id           String           @id @default(cuid())
  agencyId     String
  provider     OAuthProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  connectedBy  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  status       ConnectionStatus @default(CONNECTED)
  agency       Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [connectedBy], references: [id])

  @@unique([agencyId, provider])
  @@index([agencyId])
  @@map("agency_connections")
}

model Client {
  id                  String   @id @default(cuid())
  name                String
  slug                String
  active              Boolean  @default(true)
  phone               String?
  email               String?
  agencyId            String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  integrations        Json     @default("{}")
  reportConfig        Json     @default("{}")
  metaAdAccountId     String?
  googleAdsCustomerId String?
  agency              Agency   @relation(fields: [agencyId], references: [id])
  metrics             Metric[]
  reports             Report[]

  @@unique([agencyId, slug])
  @@map("clients")
}

model Metric {
  id        String       @id @default(cuid())
  clientId  String
  agencyId  String
  source    MetricSource
  period    DateTime
  data      Json
  fetchedAt DateTime     @default(now())
  client    Client       @relation(fields: [clientId], references: [id])

  @@unique([clientId, source, period])
  @@index([agencyId])
  @@map("metrics")
}

model Report {
  id                 String       @id @default(cuid())
  clientId           String
  agencyId           String
  period             DateTime
  status             ReportStatus @default(PENDING)
  pdfUrl             String?
  aiAnalysis         String?
  errorMessage       String?
  sentAt             DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  aiAnalysisInternal String?
  /// Prompt personalizado preenchido pelo analista na hora de gerar o relatório.
  customPrompt       String?
  /// Lista simples de métricas de foco para Google Ads (ex.: ["CONVERSIONS","CPA","ROAS"]).
  googleAdsFocus     String[]     @default([])
  /// Lista simples de métricas de foco para Meta Ads (ex.: ["CONVERSIONS","CPA","ROAS"]).
  metaAdsFocus       String[]     @default([])
  client             Client       @relation(fields: [clientId], references: [id])

  @@unique([clientId, period])
  @@index([agencyId])
  @@index([status])
  @@map("reports")
}

enum UserRole {
  ADMIN
  ANALYST
}

enum OAuthProvider {
  GOOGLE
  META
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
}

enum MetricSource {
  GOOGLE_ANALYTICS
  GOOGLE_SEARCH_CONSOLE
  META_ADS
}

enum ReportStatus {
  PENDING
  INGESTING
  PROCESSING
  ANALYZING
  COMPILING
  STORING
  DELIVERING
  COMPLETED
  FAILED
  PARTIAL
}
